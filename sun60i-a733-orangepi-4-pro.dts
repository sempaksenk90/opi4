&ufs {
       /* thinned: NO UFS CHIP on this board variant. Disabled at boot to
        * silence 67 lines of PHY-timeout spam.
        * Can be enabled at runtime via DT overlay (see overlays/ufs-enable.dtso):
        *   mkdir /sys/kernel/config/device-tree/overlays/ufs-on
        *   cat /lib/firmware/overlays/ufs-enable.dtbo > /sys/kernel/config/device-tree/overlays/ufs-on/dtbo
        */
       vcc-supply = <&reg_dldo6>;
       vccq-supply = <&reg_dcdc8>;
       vccq2-supply = <&reg_dcdc8>;
       status = "disabled";
};

/* thinned: disable power-domain test nodes for removed subsystems
 * (GPU, NPU, PCIe, camera/VI, display, video encoder/decoder) to silence
 * deferred-probe noise and 'runtime_suspend disable clock' warnings.
 * pd_usb2_test left ENABLED (status="okay" from base dtsi) — it's the only
 * consumer of SUN60IW2_PCK_USB2 power domain, which xhci2 needs to probe.
 */
&pd_vi_test       { status = "disabled"; };
&pd_npu_test      { status = "disabled"; };
&pd_gpu_top_test  { status = "disabled"; };
&pd_gpu_core_test { status = "disabled"; };
&pd_pcie_test     { status = "disabled"; };
&pd_de_sys_test   { status = "disabled"; };
&pd_vo_test       { status = "disabled"; };
&pd_vo1_test      { status = "disabled"; };
&pd_ve_dec_test   { status = "disabled"; };
&pd_ve_enc_test   { status = "disabled"; };
/* &pd_usb2_test left at status="okay" — needed for xhci2 to probe */

