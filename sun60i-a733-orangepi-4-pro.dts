        pwm1_3_pins_sleep: pwm1@1 {
                pins = "PG2";
                function = "gpio_in";
                bias-pull-down;
        };

        pwm1_9_pins_active: pwm1@0 {
                pins = "PK5";
                function = "pwm1_9";
                drive-strength = <10>;
