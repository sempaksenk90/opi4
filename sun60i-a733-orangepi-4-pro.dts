// SPDX-License-Identifier: (GPL-2.0+ or MIT)
//
// Thinned for USB-device-only programmer image (FunctionFS bulk in/out only).
//
// KEPT:  usbc2/xhci2 (dr_mode=peripheral, USB3.0 device on a600000-xhci),
//        u2phy, serdes/combophy0 (USB3 serdes), sdc0, sdc2, ufs,
//        pio/r_pio (GPIO), twi* / s_twi* (I2C), uart* (UART).
//
// USB gadget: ONLY FunctionFS (CONFIG_USB_F_FS + CONFIG_USB_CONFIGFS_F_FS).
//   Dropped: ACM, SERIAL, NCM, RNDIS, MASS_STORAGE, UAC1, UVC, HID, PRINTER,
//            USB_ROLE_SWITCH, USB_NET, NET/INET core (no RNDIS/NCM consumer).
//
// DISABLED per build spec:
//   - GPU, NPU
//   - Display (dsi0 already commented out; touchscreen disabled in twi5)
//   - Ethernet / WiFi / BT (addr_mgt + all related PHY/MAC drivers off in .config)
//   - Camera (vind0/csi*/mipi* already commented out)
//   - Sound (es8388 in twi7 disabled; ac101 in s_twi2 already disabled)
//   - PCIe host (AW_PCIE_RC off in .config; serdes retained for USB3)
//   - SPI-NOR (spi0 disabled; AW_MTD_SPI_NOR off in .config)
//   - USB host mode (EHCI/OHCI/XHCI HCDs off in .config; only DWC3-peripheral kept)
//   - LED (gpio-leds status_led disabled; ledc disabled; CONFIG_LEDS_* off in .config)
//   - sdc3 (eMMC) — not in keep-list; only sdc0 / sdc2 / UFS retained
//

/dts-v1/;

#include "sun60iw2p1.dtsi"
//#define TYPEC_DP 1
/{
        board = "A733";
        compatible = "xunlong,orangepi-4-pro", "arm,sun60iw2p1";
        aliases {
                arisc-config = &arisc_config;
                pmu0 = &pmu0;
                bat_supply = &bat_power_supply;
        };

        reg_usb0_vbus: usb0-vbus {
        compatible = "regulator-fixed";
        regulator-name = "usb0-vbus";
        regulator-min-microvolt = <5000000>;
        regulator-max-microvolt = <5000000>;
        //gpio = <&r_pio PL 2 GPIO_ACTIVE_HIGH>;  ← COMMENTED OUT
        //enable-active-high;
        };

        reg_usb1_vbus: usb1-vbus {
                compatible = "regulator-fixed";
                regulator-name = "usb1-vbus";
                regulator-min-microvolt = <5000000>;
                regulator-max-microvolt = <5000000>;
                regulator-enable-ramp-delay = <1000>;
                gpio = <&pio PB 7 GPIO_ACTIVE_LOW>;
                enable-active-low;
        };

        //wifi_power_en: wifi_power_en {
        //      compatible = "regulator-fixed";
        //      regulator-name = "wifi_power_en";
        //      regulator-min-microvolt = <3300000>;
        //      regulator-max-microvolt = <3300000>;
        //      regulator-enable-ramp-delay = <1000>;
        //      gpio = <&pio PB 4 GPIO_ACTIVE_HIGH>;
        //      enable-active-high;
        //      regulator-always-on;
        //      regulator-boot-on;
        //};

        //wifi_chip_en: wifi_chip_en {
        //      compatible = "regulator-fixed";
        //      regulator-name = "wifi_chip_en";
        //      regulator-min-microvolt = <3300000>;
        //      regulator-max-microvolt = <3300000>;
        //      regulator-enable-ramp-delay = <1000>;
        //      gpio = <&r_pio PM 1 GPIO_ACTIVE_HIGH>;
        //      enable-active-high;
        //      regulator-always-on;
        //      regulator-boot-on;
        //};

        //eeprom_wp: eeprom-wp {
        //      compatible = "regulator-fixed";
        //      regulator-name = "eeprom_wp";
        //      regulator-min-microvolt = <3300000>;
        //      regulator-max-microvolt = <3300000>;
        //      regulator-enable-ramp-delay = <1000>;
        //      gpio = <&pio PC 7 GPIO_ACTIVE_HIGH>;
        //      enable-active-high;
        //      regulator-always-on;
        //      regulator-boot-on;
        //};

        arisc_config: arisc_config {
                s_uart_config{
                        pins = "PL2", "PL3";
                        function = <3>, <3>;
                        status = "disabled";
                };
        };

        //fan0: pwm-fan {
        //      compatible = "pwm-fan";
        //      #cooling-cells = <2>; 
        //      cooling-levels = <0 18 102 170 255>;
        //      pwms = <&s_pwm0 7 25000 0>;
        //};

        leds {
                compatible = "gpio-leds";
                status = "disabled";   /* thinned: LED removed per build spec */

                led-0 {
                        label = "status_led";
                        gpios = <&pio PB 6 GPIO_ACTIVE_HIGH>;
                        linux,default-trigger = "heartbeat";
                        status = "disabled";
                };

                //led-1 {
                //      label = "radxa:green:power";
                //      gpios = <&pio PJ 26 GPIO_ACTIVE_LOW>;
                //      linux,default-trigger = "default-on";
                //};
        };

};

&ccu {
        clk-init-gate = <1>;
};

