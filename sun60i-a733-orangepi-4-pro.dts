/*
 * usb_port_type: usb mode. 0-device, 1-host, 2-otg.
 * usb_detect_type: usb hotplug detect mode. 0-none, 1-vbus/id detect, 2-pmu detect, 3-tcpm detect.
 * usb_detect_mode: 0-thread scan, 1-id gpio interrupt, 2-pmu notify.
 * usb_id_gpio: gpio for id detect.
 * usb_det_vbus_gpio: gpio for id detect. gpio or "axp_ctrl".
 * usb_wakeup_suspend：0-SUPER_STANDBY, 1-USB_STANDBY.
 */




/* ── USB1: Host (wakeup source, unchanged) ── */



/* ── USB0 / OTG: DISABLED ──
 * usbc0 (OTG manager) and udc (USB 2.0 device controller) are NOT used.
 * USB device mode is provided exclusively via the USB 3.0 path:
 *   usbc2 (sunxi-plat-dwc3) → xhci2 (snps,dwc3) — dr_mode=peripheral
 * Keeping usbc0/udc disabled avoids duplicate UDC registration and
 * avoids the Type-C / OTG manager overhead we don't need.
 */
&usbc0 {
        status = "disabled";
};

&udc {
        status = "disabled";
};

/* ── USB2/xHCI: USB3 Type-A DEVICE MODE ──
 *
 * usbc2@12 is a PURE LOGICAL/GLUE node — its reg=<0x0 0x12 ...> is just a
 * placeholder ID, NOT a real MMIO address. The real hardware is the child
 * xhci2-controller@6a00000 (reg=0x06a00000, a genuine MMIO base).
 *
 * The BSP cadence-combophy driver has a `.type = "usbc2"` of_match entry
 * (sunxi-specific soft-match hack) that tries to probe usbc2 directly.
 * It calls platform_get_resource(IORESOURCE_MEM, 0) which correctly
 * returns NULL because there's no real register block at 0x12.
 * That triggers: "sunxi-cadence-combophy 12.usbc2: invalid resource (null)"
 *
 * Fix: delete device_type="usbc2" by overriding it with an empty string.
 * The dwc3_sunxi_plat glue driver matches usbc2 via compatible=
 * "allwinner,sunxi-plat-dwc3" (inherited from base dtsi), NOT via
 * device_type, so clearing device_type doesn't break the DWC3 path.
 * The combophy driver's `.type="usbc2"` soft-match then fails to match,
 * so it skips usbc2 and only probes the real serdes@6c00000 node.
 *
 * drvvbus-supply is required because dwc3_sunxi_plat calls
 * devm_regulator_get(dev, "drvvbus") and defers probe if NULL.
 * Point at the always-on fixed regulator; aw,vbus-shared-quirk prevents
 * the glue from actually toggling VBUS via this regulator.
 */
&usbc2 {
        /* Override device_type to break cadence-combophy's .type="usbc2" match */
        device_type = "";
        usb_detect_type = <0x3>;        /* DWC3_DETECT_TYPE_UNKNOWN — skip PMU CC scan */
        usb_detect_mode = <0x3>;        /* DWC3_DETECT_MODE_UNKNOWN */
        aw,vbus-shared-quirk;
        drvvbus-supply = <&reg_usb0_vbus>;
        status = "okay";
};

&xhci2 {
        dr_mode       = "peripheral";
        phys = <&u2phy>, <&combo0_usb>;
        phy-names = "usb2-phy", "usb3-phy";
        assigned-clocks = <&ccu CLK_USB2_SUSPEND>, <&ccu CLK_USB2_MF>;
        assigned-clock-rates = <24000000>, <400000000>;
        maximum-speed = "super-speed";
        status = "okay";
};

&u2phy {
    status = "okay";
};

&combo0_dp {
    status = "disabled";
};

&combo1_pcie {
    status = "disabled";
};

/* ── SerDes / ComboPHY: Enable + fix lane map for USB3 (non-TypeC) ──
 * Use &combophy0 label reference (NOT re-declaring the node) so we MERGE
 * with the base dtsi combophy0@6c01000 definition (which has reg, clocks,
 * and child phy nodes combo0_usb + combo0_dp). Re-declaring the node
 * created a duplicate that confused the phy framework.
 */
&serdes {
    serdes1v8-supply = <&reg_cldo5>;
    status = "okay";
};

&combophy0 {
    lane_invert = <0 0 0 0>;
    lane_remap = <2 3 0 1>;          /* USB3 Type-A lane order, NOT TypeC/DP */
};


&twi0 {
        clock-frequency = <400000>;
        pinctrl-0 = <&twi0_pins_default>;
        pinctrl-1 = <&twi0_pins_sleep>;
        pinctrl-names = "default", "sleep";
        /* For stability and backwards compatibility, we recommend setting ‘twi_drv_used’ to 1 */
        twi_drv_used = <0>;
        no_suspend = <1>;
        twi-supply = <&reg_cldo3>;
        status = "disabled";

                //eeprom@50 {
                //      compatible = "atmel,24c16";
                //      reg = <0x50>;
                //      //num-addresses = <1>;
                //      status = "okay";
                //};
};

