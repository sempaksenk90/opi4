        twi_drv_used = <1>;
        twi-supply = <&reg_dc1sw2>;
        status = "disabled";   /* thinned: no active client (touchscreen disabled) */

        touchscreen: touchscreen@14 {
                compatible = "goodix,gt9271";
                reg = <0x14>;
                interrupt-parent = <&pio>;
                interrupts = <PJ 25 IRQ_TYPE_LEVEL_HIGH>;
                irq-gpios = <&pio PJ 25 GPIO_ACTIVE_HIGH>;
                reset-gpios = <&pio PG 10 GPIO_ACTIVE_HIGH>;
                touchscreen-inverted-x;
                //touchscreen-inverted-y;
                touchscreen-swapped-x-y;
                touchscreen-size-x = <1280>;
                touchscreen-size-y = <800>;
                status = "disabled";   /* thinned: display-related touchscreen removed */
        };
};

&twi7 {
        clock-frequency = <400000>;
        pinctrl-0 = <&twi7_pins_default>;
        pinctrl-1 = <&twi7_pins_sleep>;
        pinctrl-names = "default", "sleep";
        /* For stability and backwards compatibility, we recommend setting ‘twi_drv_used’ to 1 */
        twi_drv_used = <1>;
        twi-supply = <&reg_bldo2>;
        status = "disabled";   /* thinned: no active client (es8388 disabled) */

        es8388: es8388@10{
                status = "disabled";   /* thinned: sound codec removed per build spec */
                #sound-dai-cells = <0>;
                compatible = "everest,es8388", "everest,es8389";
                reg = <0x10>;
                assigned-clock-rates = <12288000>;
                //pinctrl-names = "default";
                //pinctrl-0 = <&i2s2m1_mclk>;
        };
};

