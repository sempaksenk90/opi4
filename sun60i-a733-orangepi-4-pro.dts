                                swin-supply = <&reg_dcdc1>;
                                regulator-boot-on;
                                regulator-always-on;
                        };
                        reg_dc1sw2: dc1sw2 {
                                regulator-name = "axp8191-dc1sw2";
                                swin-supply = <&reg_dcdc1>;
