&cpu0 {
        cpu-supply = <&reg_dcdc5>;
};

&dsufreq {
        dsu-supply = <&reg_dcdc5>;
};

&cpu6 {
        cpu-supply = <&reg_dcdc3>;
};

&npu {
        npu-supply = <&reg_dcdc2>;
        status = "disabled";   /* thinned: NPU removed per build spec */
};

&addr_mgt {
        compatible     = "allwinner,sunxi-addr_mgt";
        type_addr_wifi = <0x0>;
        type_addr_bt   = <0x0>;
        type_addr_eth  = <0x0>;
        status         = "disabled";   /* thinned: wifi/bt/eth removed per build spec */
};




